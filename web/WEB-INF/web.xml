<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>AddNewUser</servlet-name>
        <servlet-class>controller.AddNewUser</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateUserInformation</servlet-name>
        <servlet-class>controller.UpdateUserInformation</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ViewPermissionList</servlet-name>
        <servlet-class>controller.ViewPermissionList</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PermissionDetail</servlet-name>
        <servlet-class>controller.PermissionDetail</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AddNewPermission</servlet-name>
        <servlet-class>controller.AddNewPermission</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditPermission</servlet-name>
        <servlet-class>controller.EditPermission</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateRole</servlet-name>
        <servlet-class>controller.UpdateRole</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddNewUser</servlet-name>
        <url-pattern>/AddNewUser</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateUserInformation</servlet-name>
        <url-pattern>/UpdateUserInformation</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ViewPermissionList</servlet-name>
        <url-pattern>/ViewPermissionList</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PermissionDetail</servlet-name>
        <url-pattern>/PermissionDetail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AddNewPermission</servlet-name>
        <url-pattern>/AddNewPermission</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditPermission</servlet-name>
        <url-pattern>/EditPermission</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateRole</servlet-name>
        <url-pattern>/UpdateRole</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
